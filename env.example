# Copy this file to `.env` before running locally without Docker:
#   cp env.example .env
# (The repository tooling blocks committing dotfiles, so the example ships
#  under this name. Docker Compose injects these values directly — see compose.)

# Database (Postgres). With Docker Compose the host is the `db` service.
DATABASE_URL="postgresql://abad:abad@localhost:5432/abad?schema=public"
POSTGRES_USER=abad
POSTGRES_PASSWORD=abad
POSTGRES_DB=abad

# Admin panel gate (catalogs + D0-D9 mapping editor). CHANGE IN PRODUCTION.
ADMIN_PASSWORD=abad-admin
SESSION_SECRET=change-me-in-production

# Optional API key for the machine-readable /api/athenea endpoints.
# If set, callers must send `x-api-key: <value>`. Leave empty to require the
# admin session cookie instead.
EXPORT_API_KEY=

# Athenea export knobs — UNKNOWN in the source docs (see HANDOFF.md).
# Gender key: "SEXO" (matches sample payload) or "IDSEXO" (matches request table).
ATHENEA_SEX_EXPORT_KEY=SEXO
# FECHANACIMIENTO format (tokens: yyyy MM dd HH mm ss).
ATHENEA_DATE_FORMAT=yyyy-MM-dd
