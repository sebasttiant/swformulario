# Copy this file to `.env` before running:
#   cp env.example .env
#   docker compose up -d --build        # production (default)
#
# (The repository tooling blocks committing dotfiles, so the example ships under
#  this name — it is the canonical `.env` template. Docker Compose injects these
#  values directly; see docker-compose.yml.)
# Never commit a real `.env`. Put real secrets only there, never in this file.

# Database (Postgres). With Docker Compose the host is the `db` service.
POSTGRES_USER=abad
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=abad
# Only needed when running the app OUTSIDE Docker (reachable Postgres).
DATABASE_URL="postgresql://abad:change-me-strong-db-password@localhost:5432/abad?schema=public"

# Session cookie signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-with-openssl-rand-hex-32

# Initial super admin OVERRIDE (optional). On a clean install the seed creates a
# default SUPER_ADMIN (admin@ilasesorias.com) — change its password from
# /admin/users after logging in. Set these ONLY to override the initial creation
# on a fresh DB; they are ignored once the owner exists (manual changes win).
# Leave blank to use the internal default. Stored HASHED, never in plaintext.
# SUPERADMIN_EMAIL=
# SUPERADMIN_PASSWORD=

# "true" seeds catalogs + D0-D9 mapping + demo patients on a fresh DB
# (idempotent upserts). Recommended for a first demo; set "false" afterwards.
RUN_SEED_ON_START=true

# Optional API key for the machine-readable /api/athenea endpoints.
# If set, callers must send `x-api-key: <value>`. Leave empty to require the
# admin session cookie instead.
EXPORT_API_KEY=

# Athenea export knobs — UNKNOWN in the source docs (see HANDOFF.md).
# Gender key: "SEXO" (matches sample payload) or "IDSEXO" (matches request table).
ATHENEA_SEX_EXPORT_KEY=SEXO
# FECHANACIMIENTO format (tokens: yyyy MM dd HH mm ss).
ATHENEA_DATE_FORMAT=yyyy-MM-dd
